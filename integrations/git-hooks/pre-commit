#!/bin/bash

echo "🔍 SIL Pre-Commit Scan Running..."

FILES=$(git diff --cached --name-only)

for file in $FILES
do
    if [ -f "$file" ]; then
        if grep -q '#\[cfg(test)\]' "$file" 2>/dev/null; then
            continue
        fi
        DECISION=$(sil-cli --input "$(cat "$file")" 2>&1 | grep "^DECISION")
        echo "$DECISION" | grep -q "BLOCKED"
        if [ $? -eq 0 ]; then
            echo "❌ Commit BLOCKED by SIL Security Layer"
            exit 1
        fi
    fi
done

echo "✅ SIL Scan Passed"
exit 0
